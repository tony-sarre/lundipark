{
  "name": "lundipark-photography",
  "version": "1.0.0",
  "description": "Lundipark Photography — Fine art photography website with admin panel (Cloudflare Pages)",
  "private": true,
  "scripts": {
    "dev": "npx serve public -p 3000",
    "preview": "npx wrangler pages dev public",
    "deploy": "npx wrangler pages deploy public --project-name=lundipark-photography",
    "deploy:preview": "npx wrangler pages deploy public --project-name=lundipark-photography --branch=preview"
  },
  "keywords": [
    "photography",
    "portfolio",
    "lundipark",
    "cloudflare-pages"
  ],
  "author": "Lundipark Photography",
  "license": "UNLICENSED",
  "devDependencies": {
    "serve": "^14.2.0",
    "wrangler": "^3.78.0"
  }
}
